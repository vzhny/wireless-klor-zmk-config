#include "klor_common.dtsi"

/ {
	chosen {
		zmk,matrix_transform = &default_transform;
	};

	/* Saegewerk layout (38 keys): the KLOR PCB matrix is shared across all
	 * four break-off layouts (Polydactyl/Konrad/Yubitsume/Saegewerk); Saegewerk
	 * simply leaves the outer pinky column unpopulated on rows 1-2 and drops the
	 * two innermost thumb keys, compared to the full Polydactyl matrix. Derived
	 * from the LAYOUT_saegewerk() matrix macro in the upstream QMK config
	 * (github.com/GEIGEIGEIST/qmk-config-klor, klor/klor.h) so the row/col
	 * positions line up with the real PCB wiring.
	 */
	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <12>;
		rows = <4>;
		map = <
        RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                 RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10)
        RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                 RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10)
        RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(3,5) RC(3,6) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
                        RC(3,1) RC(3,2) RC(3,3)         RC(3,8) RC(3,9) RC(3,10)
		>;
	};
};

&kscan0 {
	row-gpios
		= <&pro_micro 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
		, <&pro_micro 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
		, <&pro_micro 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
		, <&pro_micro 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
		;
};

&left_encoder {
	a-gpios = <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
	b-gpios = <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
};

&right_encoder {
	a-gpios = <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
	b-gpios = <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
};